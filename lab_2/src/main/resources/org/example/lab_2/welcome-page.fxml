<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lab_2.WelcomePageController">
   <children>
      <VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0">
         <children>
            <Label fx:id="Welcome_Label" alignment="CENTER" contentDisplay="TOP" prefHeight="248.0" prefWidth="367.0" text="Welcome !" textFill="#00ff4d">
               <font>
                  <Font size="70.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" onAction="#handleBackToLoginPage" prefHeight="69.0" prefWidth="172.0" text="Back to login page" />
         </children>
      </VBox>
   </children>
</StackPane>
